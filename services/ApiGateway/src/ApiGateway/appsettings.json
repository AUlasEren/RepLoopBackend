{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:8081",
      "http://localhost:19006"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "workouts-route": {
        "ClusterId": "workout-cluster",
        "Match": {
          "Path": "/api/workouts/{**catch-all}"
        }
      },
      "exercises-route": {
        "ClusterId": "exercise-cluster",
        "Match": {
          "Path": "/api/exercises/{**catch-all}"
        }
      },
      "user-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/user/{**catch-all}"
        }
      },
      "settings-route": {
        "ClusterId": "settings-cluster",
        "Match": {
          "Path": "/api/settings/{**catch-all}"
        }
      },
      "sessions-route": {
        "ClusterId": "session-cluster",
        "Match": {
          "Path": "/api/sessions/{**catch-all}"
        }
      },
      "statistics-route": {
        "ClusterId": "statistics-cluster",
        "Match": {
          "Path": "/api/statistics/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5174/"
          }
        }
      },
      "workout-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5175/"
          }
        }
      },
      "exercise-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5176/"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5177/"
          }
        }
      },
      "settings-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5178/"
          }
        }
      },
      "session-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5179/"
          }
        }
      },
      "statistics-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5180/"
          }
        }
      }
    }
  }
}
